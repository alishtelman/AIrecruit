# Database
DATABASE_URL=postgresql+asyncpg://recruiting:recruiting@postgres:5432/recruiting

# Environment
APP_ENV=development

# JWT
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SESSION_COOKIE_NAME=airecruit_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false


# AI
GROQ_API_KEY=your-groq-api-key-here
ALLOW_MOCK_AI=true
ELEVENLABS_API_KEY=
TTS_PROVIDER=groq
TTS_FALLBACK_PROVIDER=groq
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ANTHROPIC_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=AIRecruit <noreply@airecruit.app>

# App
APP_URL=http://localhost:3000

# File storage
UPLOAD_DIR=/app/uploads
RESUME_STORAGE_DIR=/app/storage/resumes
RECORDING_STORAGE_DIR=/app/storage/recordings
MAX_RESUME_SIZE_MB=10
MAX_RECORDING_SIZE_MB=250

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001

# Backend CORS
CORS_ORIGINS=http://localhost:3000
